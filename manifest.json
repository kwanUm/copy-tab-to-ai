{
  "manifest_version": 3,
  "name": "Copy Tab to AI",
  "version": "1.0.0",
  "description": "Extract text and images from any page and paste into Claude, ChatGPT, or any AI",
  "commands": {
    "run-last-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Run last used prompt on current page"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Copy Tab to AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
